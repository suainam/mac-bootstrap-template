# User-level tools installed by agent helpers such as code-review-graph.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# Added by code-review-graph install
export PATH="$HOME/.local/bin:$PATH"

# Terminal auto-attach
# - iTerm2 provides the window shell
# - tmux owns the session, a persistent _daemon_ window, and ai-work layout
# - SSH shells stay untouched
tmwork() {
    if [[ -n "$TMUX" ]]; then
        return 0
    fi

    if (( $+commands[tmux] )); then
        local session="${TMUX_SESSION:-ai-work}"
        exec "$HOME/.local/bin/tmux-workspace.sh" "$session"
    fi
}

if [[ "${MAC_BOOTSTRAP_AUTO_ATTACH_TMUX:-1}" == "1" ]] && [[ -z "$SSH_CONNECTION" ]] && [[ -o interactive ]] && [[ -z "$TMUX" ]]; then
    tmwork
fi

# tmux owns session/layout routing.
tm() {
    case "${1:-}" in
        "")
            local session="${TMUX_SESSION:-ai-work}"
            if [[ -n "$TMUX" ]]; then
                command tmux switch-client -t "$session"
            else
                tmwork
            fi
            ;;
        list-keys)
            cat <<'EOF'
tmux keys

Prefix: Ctrl+a

- Ctrl+a \\: split left/right
- Ctrl+a -: split top/bottom
- Ctrl+a h/j/k/l: move between panes
- Ctrl+a H/J/K/L: resize panes
- Ctrl+a c: new window
- Ctrl+a n/p: next/previous window
- Ctrl+a z: zoom current pane
- Ctrl+a r: reload tmux.conf
- Ctrl+a [ : copy mode
- Ctrl+a d: detach
EOF
            ;;
        *)
            command tmux "$@"
            ;;
    esac
}
