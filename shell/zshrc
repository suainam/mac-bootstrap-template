# Suppress p10k instant prompt warning for any console I/O during init.
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Zshrc — Mac 版，适配自 AuroraOps
# Shared environment
[[ -f ~/.shell_env ]] && source ~/.shell_env

setopt NO_NOMATCH

# GUI editors such as Zed capture the login-shell environment without a TTY.
# Keep shells without an attached terminal side-effect free so env probing can
# succeed even if the shell was started with interactive flags.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

if [[ ! -o interactive || ( -z "${TMUX:-}" && ( ! -t 0 || ! -t 1 ) ) ]]; then
  return 0
fi

# ---------- Zinit ----------
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -f $ZINIT_HOME/zinit.zsh ]]; then
    command mkdir -p "${ZINIT_HOME%/*}"
    command git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "$ZINIT_HOME/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Annexes
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

# OMZ libs & plugins
zinit snippet OMZ::lib/completion.zsh
zinit snippet OMZ::lib/history.zsh
zinit snippet OMZ::lib/key-bindings.zsh
zinit snippet OMZ::lib/theme-and-appearance.zsh
zinit snippet OMZ::plugins/colored-man-pages/colored-man-pages.plugin.zsh
zinit snippet OMZP::command-not-found
zinit snippet OMZP::extract
zinit snippet OMZP::git

# Keep a native vi keymap even if the richer vi-mode plugin fails to load.
bindkey -v

# Powerlevel10k
zinit ice depth=1
zinit light romkatv/powerlevel10k
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Core editing behavior should be available on the first prompt.
zinit lucid for \
    atload"bindkey '^[[A' history-substring-search-up; bindkey '^[[B' history-substring-search-down; bindkey \"$terminfo[kcuu1]\" history-substring-search-up; bindkey \"$terminfo[kcud1]\" history-substring-search-down" \
    zsh-users/zsh-history-substring-search

# These are prompt niceties, not core editing behavior, so they can load later.
zinit wait lucid for \
    atload"_zsh_autosuggest_start" \
    zsh-users/zsh-autosuggestions

zinit wait lucid for \
    zdharma-continuum/fast-syntax-highlighting

# Vi mode should be ready before the first prompt. Loading it asynchronously can
# make the shell look like emacs mode until the plugin eventually attaches.
zinit lucid for jeffreytse/zsh-vi-mode

# Extra completion definitions can replay after prompt; native completion is
# already present via the OMZ completion lib above.
zinit wait lucid for \
    atinit"ZINIT[COMPINIT_OPTS]=-C; zicompinit; zicdreplay" \
    zsh-users/zsh-completions

# ---------- Command Line Tools ----------
# Fzf integration
eval "$(fzf --zsh)"

# Zoxide (Rust replacement for z/z.lua)
eval "$(zoxide init zsh)"
alias zi="zoxide query -i"

yy() {
    if ! (( $+commands[yazi] )); then
        echo "yazi not found in PATH. Install it with: brew install yazi" >&2
        return 127
    fi

    local tmp
    tmp="$(mktemp -t yazi-cwd.XXXXXX)" || return 1
    yazi "$@" --cwd-file="$tmp"

    local cwd
    cwd="$(command cat -- "$tmp" 2>/dev/null || true)"
    command rm -f -- "$tmp"

    if [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
        builtin cd -- "$cwd"
    fi
}

