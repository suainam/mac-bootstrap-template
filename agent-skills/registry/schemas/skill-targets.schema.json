{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "targets"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "version": {"const": 1},
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["path", "format", "strategy"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "format": {"enum": ["directory", "flat-md"]},
          "strategy": {"enum": ["symlink", "copy"]},
          "legacy_formats": {
            "type": "array",
            "items": {"enum": ["directory", "flat-md"]},
            "uniqueItems": true
          }
        }
      }
    }
  }
}
