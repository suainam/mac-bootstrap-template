# Ghostty terminal config

# Font - SF Mono (Apple's system monospace)
font-family = "SF Mono"
font-size = 14

# Theme - Gruvbox Dark (matches zellij)
background = 282828
foreground = ebdbb2

palette = 0=#282828
palette = 1=#cc241d
palette = 2=#98971a
palette = 3=#d79921
palette = 4=#458588
palette = 5=#b16286
palette = 6=#689d6a
palette = 7=#a89984
palette = 8=#928374
palette = 9=#fb4934
palette = 10=#b8bb26
palette = 11=#fabd2f
palette = 12=#83a598
palette = 13=#d3869b
palette = 14=#8ec07c
palette = 15=#ebdbb2

# Behavior
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
copy-on-select = true
clipboard-paste-protection = false

# Window
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = tabs
macos-option-as-alt = true
window-new-tab-position = end

# Remap cmd+n to open a new tab instead of a new window
keybind = cmd+n=new_tab

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title
term = xterm-256color

# Ghostty owns terminal startup only.
# Session/layout routing stays in shell + zellij via these env defaults.
command = /bin/zsh -l -c "export ZELLIJ_SESSION=ai-work ZELLIJ_DEFAULT_LAYOUT=ai-work MAC_BOOTSTRAP_ZJ_AUTO_ATTACH=1; exec /bin/zsh -l"
