# Host bind for the web UI. Keep `0.0.0.0` if the server should be reachable
# from other machines on the LAN / bastion network.
GITEA_HTTP_BIND=0.0.0.0

# Host bind for Git over SSH.
GITEA_SSH_BIND=0.0.0.0

# Host ports exposed by Docker Compose.
GITEA_HTTP_PORT=13000
GITEA_SSH_PORT=2222

# Public URL Gitea prints into clone URLs and links.
GITEA_DOMAIN=10.0.103.217
GITEA_ROOT_URL=http://10.0.103.217:13000/
GITEA_SSH_DOMAIN=10.0.103.217

# Optional outbound proxy for Gitea itself.
# This helps when the bastion can only reach the internet through the
# freellmapi/mimo proxy path. It does not affect Docker image pulls.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,db,gitea

# Persistent secrets / images.
POSTGRES_PASSWORD=change-me
GITEA_IMAGE=docker.gitea.com/gitea:1.26.2
POSTGRES_IMAGE=postgres:16
