# code-server .env — 不入 git
CODE_SERVER_PASSWORD=your-strong-password-here
CODE_SERVER_WORKSPACE_DIR=/workspace
CODE_SERVER_CONFIG_DIR=./data/config
CODE_SERVER_DATA_DIR=./data/code-server
CODE_SERVER_SSL_DIR=./data/nginx-ssl
CODE_SERVER_HTTP_PORT=59200
CODE_SERVER_HTTPS_PORT=59443
# Comma-free host:port value used by code-server --trusted-origins for the browser HTTPS entrypoint.
CODE_SERVER_TRUSTED_ORIGINS=10.0.103.217:59443
CODE_SERVER_CERT_IP=10.0.103.217
OPENAI_API_KEY=placeholder
