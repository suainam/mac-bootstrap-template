layout {
    tab name="AI-Work" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane command="claude" cwd="~/work" name="Claude"
                pane command="/bin/zsh" cwd="~/work" name="SSH" {
                    args "-l"
                }
            }
            pane command="/bin/zsh" cwd="~/work" name="Zsh" {
                args "-l"
            }
        }
    }
}
