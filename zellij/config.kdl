            background "#000000"
            emphasis_0 "#D65D0E"
            emphasis_1 "#689D6A"
            emphasis_2 "#B16286"
            emphasis_3 "#000000"
        }
        exit_code_success {
            base "#98971A"
            background "#000000"
            emphasis_0 "#689D6A"
            emphasis_1 "#3C3836"
            emphasis_2 "#B16286"
            emphasis_3 "#458588"
        }
        exit_code_error {
            base "#CC241D"
            background "#000000"
            emphasis_0 "#D79921"
            emphasis_1 "#000000"
            emphasis_2 "#000000"
            emphasis_3 "#000000"
        }
        multiplayer_user_colors {
            player_1 "#B16286"
            player_2 "#458588"
            player_3 "#000000"
            player_4 "#D79921"
            player_5 "#689D6A"
            player_6 "#000000"
            player_7 "#CC241D"
            player_8 "#000000"
            player_9 "#000000"
            player_10 "#000000"
        }
