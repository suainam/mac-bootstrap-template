        },
        "write-a-skill": {
          "distribution_state": "staged",
          "agents": ["claude", "codex", "opencode", "cross-agent"],
          "reason": "skills.sh page exists and shows: npx skills add https://github.com/mattpocock/skills --skill write-a-skill; stage by default because it is a skill-authoring helper"
        },
        "zoom-out": {
          "distribution_state": "staged",
          "agents": ["claude", "codex", "opencode", "cross-agent"],
          "reason": "skills.sh page exists and shows: npx skills add https://github.com/mattpocock/skills --skill zoom-out; stage by default until routing/noise is confirmed"
        },
        "setup-matt-pocock-skills": {
          "distribution_state": "disabled"
        },
        "tdd": {
          "distribution_state": "merged",
          "reason": "TDD cluster will keep one canonical skill"
        }
