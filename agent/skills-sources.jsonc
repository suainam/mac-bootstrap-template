          "reason": "User-confirmed stage; useful for infra/data projects but not a default global install"
        },
        "data-throughput-accelerator": {
          "distribution_state": "staged",
          "agents": ["claude", "codex", "opencode", "cross-agent"],
          "reason": "User-confirmed stage; keep source available for ETL/backfill work"
        },
        "search-first": {
          "agents": ["claude", "codex", "opencode", "cross-agent"]
        },
        "documentation-lookup": {
          "agents": ["claude", "codex", "opencode", "cross-agent"]
        },
        "postgres-patterns": {
          "distribution_state": "staged"
        },
        "database-migrations": {
          "distribution_state": "staged"
        },
        "data-scraper-agent": {
          "distribution_state": "staged"
        },
        "python-patterns": {
          "distribution_state": "merged",
          "reason": "merged conceptually with python-data-analysis / coding Python support"
        },
        "tdd-workflow": {
          "distribution_state": "merged",
          "reason": "TDD cluster will keep one canonical skill"
        },
        "verification-loop": {
          "distribution_state": "merged",
          "reason": "merged with eval-loop / verification workflow"
        },
        "pytorch-patterns": {
          "distribution_state": "disabled"
        },
        "mle-workflow": {
          "distribution_state": "disabled"
        },
        "clickhouse-io": {
          "distribution_state": "disabled"
        }
      }
    },

