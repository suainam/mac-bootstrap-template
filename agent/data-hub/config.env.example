# Agent Data Hub 配置 (存放在 private/agent/.obsidian_daily.env)

# Obsidian Vault 路径
OBSIDIAN_VAULT_DIR="$HOME/work/projects/product_strategy"

# 需要提取 git log 的搜索根目录，逗号分隔
GIT_SEARCH_ROOTS="$HOME/work/config,$HOME/work/projects"

# SQLite 数据库路径 (相对于 home 目录或绝对路径)
AGENT_DB_PATH="$HOME/work/config/mac-bootstrap/private/agent/data/agent_history.db"

# LLM API keys (多 key 逗号分隔，用于 429 轮询 fallback，或者不填优先走 cli)
# GEMINI_API_KEYS="AIza...,AIza..."

# 代理配置 (如果需要)
# LLM_BASE_URL="http://10.0.103.217:3001/v1"
