{
  // LLM backend 有序 fallback 列表
  // llm_filter.py 依次尝试，第一个成功的返回结果。
  // 将此文件复制到 private/agent/llm_backends.jsonc 并填入真实配置。
  "backends": [
    {
      "name": "freellmapi-example",
      "base_url": "http://10.x.x.x:3001/v1",
      "api_key": "sk-placeholder",
      "model": "Qwen/ModelName",
      "timeout": 30
    }
  ],
  // API backend 全部失败后，依次尝试以下 CLI agent
  "cli_fallbacks": ["codex", "agy", "opencode", "claude"],
  // 过滤阈值
  "filter": {
    "chat_threshold": 0.5,
    "external_threshold": 0.3,
    "max_workers": 10
  }
}
