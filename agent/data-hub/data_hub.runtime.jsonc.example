{
  // Copy to private/agent/data_hub.runtime.jsonc and fill private values.
  "paths": {
    "repo_root": "$HOME/work/config/mac-bootstrap",
    "template_root": "$HOME/work/config/mac-bootstrap/template",
    "data_hub_dir": "$HOME/work/config/mac-bootstrap/template/agent/data-hub",
    "db_path": "$HOME/work/config/mac-bootstrap/private/agent/data/agent_history.db",
    "vault_dir": "$HOME/work/knowledge",
    "daily_dir": "10_Periodic/Daily",
    "runs_dir": "$HOME/work/config/mac-bootstrap/private/agent/data/runs",
    "git_search_roots": "$HOME/work/config,$HOME/work/projects"
  },
  "sources": {
    "inputs": [
      {"source_type": "meeting_note", "relative_root": "raw/sources/Meetings", "pattern": "*.md"},
      {"source_type": "mind_map", "relative_root": "raw/sources/Mindmaps", "pattern": "*.xmind"},
      {"source_type": "wiki_page", "relative_root": "raw/sources/Wiki-Clips", "pattern": "*.md"},
      {"source_type": "wiki_pdf", "relative_root": "raw/sources/Wiki-Clips", "pattern": "*.pdf"},
      {"source_type": "wiki_html", "relative_root": "raw/sources/Wiki-Clips", "pattern": "*.html"}
    ]
  },
  "llm_wiki": {
    "enabled": false,
    "api_base": "http://127.0.0.1:19828",
    "project_root": "$HOME/work/knowledge",
    "project_id": "",
    "token_env": "LLM_WIKI_TOKEN",
    "token": "",
    "exclude_dirs": ["70_Summaries"]
  },
  "summary": {
    "root_relative": "70_Summaries",
    "daily_dir": "Daily",
    "weekly_dir": "Weekly",
    "monthly_dir": "Monthly",
    "quarterly_dir": "Quarterly",
    "yearly_dir": "Yearly",
    "deployment_start": "2026-07-10"
  },
  "agent_logs": {
    "claude_projects_dir": "$HOME/.claude/projects",
    "codex_sessions_dir": "$HOME/.codex/sessions",
    "opencode_sessions_dir": "$HOME/.config/opencode/sessions",
    "agy_brain_dir": "$HOME/.gemini/antigravity-cli/brain"
  },
  "llm": {
    "backends": [
      {
        "name": "freellmapi-example",
        "kind": "openai_api",
        "base_url": "http://10.x.x.x:3001/v1",
        "api_key": "sk-placeholder",
        "model": "Qwen/ModelName",
        "timeout": 10
      },
      {
        "name": "huang-gpt-example",
        "kind": "openai_api",
        "base_url": "https://example.com/v1",
        "api_key": "sk-placeholder",
        "model": "gpt-example",
        "timeout": 10
      },
      {"name": "opencode", "kind": "opencode_cli", "timeout": 10},
      {"name": "codex", "kind": "codex_cli", "timeout": 10},
      {"name": "agy", "kind": "agy_cli", "timeout": 10},
      {"name": "claude", "kind": "claude_cli", "timeout": 10}
    ],
    "filter": {
      "chat_threshold": 0.5,
      "external_threshold": 0.3,
      "max_workers": 10
    }
  },
  "workflow": {
    "default_max_attempts": 1
  }
}
